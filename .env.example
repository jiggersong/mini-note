# ============================================================
# mini-note 环境变量配置
# 复制为 .env 后填写实际值。.env 不会被 git 追踪。
# ============================================================

# --- 阿里云 OSS 备份（必填）---
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET=your-bucket-name
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS 快照存储前缀，默认 snapshots
OSS_PREFIX=snapshots

# --- OSS 客户端加密（建议启用）---
# 加密密钥，留空则不做客户端加密
OSS_ENCRYPTION_KEY=

# --- 文件上限（可选，使用默认值可不填）---
# PDF 最大页数
MAX_PDF_PAGES=100
# Office 文件最大大小（MB）
MAX_OFFICE_MB=20
# 文本文件最大大小（MB）
MAX_TEXT_MB=2
# 图片最大大小（MB）
MAX_IMAGE_MB=20
# 音频最大时长（分钟）
MAX_AUDIO_MINUTES=30
# 视频最大时长（分钟）
MAX_VIDEO_MINUTES=5
